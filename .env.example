# Google AI Studio — create a key at https://aistudio.google.com/apikey
# Required for POST /api/tarot-reading (full three-card spread synthesis).
# On Railway: Project → Variables → add GEMINI_API_KEY (do not commit real keys).
GEMINI_API_KEY=

# Optional. Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Fish Audio — HAL 9000 TTS (https://fish.audio/app/api-keys/)
# Required for POST /api/tts/speech. On Railway: add FISH_API_KEY to Variables.
FISH_API_KEY=

# Optional. Default: 3892b24d0b11449a8d60eae269d7ee73 (community HAL voice)
# FISH_HAL_VOICE_ID=3892b24d0b11449a8d60eae269d7ee73

# Railway Postgres — required for login, sessions, and saved readings.
# 1. Railway project → Add service → PostgreSQL
# 2. Copy DATABASE_URL from the Postgres service variables
# 3. Reference it on your app service (or paste the connection string)
DATABASE_URL=

# Session signing secret — required in production (e.g. openssl rand -hex 32)
SESSION_SECRET=
